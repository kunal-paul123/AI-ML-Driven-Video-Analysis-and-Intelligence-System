# ─────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────
APP_NAME="VideoAI Surveillance System"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# ─────────────────────────────────────────────
# Neon DB (PostgreSQL)
# Get this from: https://console.neon.tech
# Format: postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/videoai?sslmode=require

# ─────────────────────────────────────────────
# Security (JWT)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────
# CORS - Frontend URL
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Video Processing
# ─────────────────────────────────────────────
MAX_CONCURRENT_STREAMS=10
FRAME_EXTRACTION_FPS=5
MAX_VIDEO_FILE_SIZE_MB=500

# ─────────────────────────────────────────────
# ML Engine
# ─────────────────────────────────────────────
YOLO_MODEL_PATH=../ml-engine/weights/yolov8n.pt
ML_CONFIDENCE_THRESHOLD=0.5
ML_IOU_THRESHOLD=0.45
